#!/usr/bin/env bash

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BUILDKITE_ROOT="${TEST_QUEUE_SMOKE_BUILDKITE_ROOT:-"$ROOT/../buildkite"}"
BKGO_ROOT="$BUILDKITE_ROOT/bkgo"
DATABASE_URL="${TEST_QUEUE_SMOKE_DATABASE_URL:-postgres://postgres@localhost:5433/buildkite_analytics_development?sslmode=disable}"
QUEUE_NAME="${TEST_QUEUE_SMOKE_QUEUE_NAME:-custom/lease smoke}"

if [ ! -d "$BKGO_ROOT" ]; then
  echo "bkgo repo not found at $BKGO_ROOT; set TEST_QUEUE_SMOKE_BUILDKITE_ROOT" >&2
  exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
  echo "python3 is required for port selection and response validation" >&2
  exit 1
fi

if ! command -v curl >/dev/null 2>&1; then
  echo "curl is required for health checks and queue API calls" >&2
  exit 1
fi

TMPDIR="$(mktemp -d)"
SERVER_PID=""

cleanup() {
  if [ -n "$SERVER_PID" ] && kill -0 "$SERVER_PID" >/dev/null 2>&1; then
    kill "$SERVER_PID" >/dev/null 2>&1 || true
    wait "$SERVER_PID" >/dev/null 2>&1 || true
  fi
  rm -rf "$TMPDIR"
}
trap cleanup EXIT

PORT="${TEST_QUEUE_SMOKE_PORT:-$(python3 - <<'PY'
import socket

sock = socket.socket()
sock.bind(("127.0.0.1", 0))
print(sock.getsockname()[1])
sock.close()
PY
)}"

echo "--- Building local bktec and bkgo binaries"
(cd "$ROOT" && go build -o "$TMPDIR/bktec" .)
(cd "$BKGO_ROOT" && go build -o "$TMPDIR/bkgo" .)

echo "--- Starting bkgo test-queue on port $PORT"
env -i \
  HOME="${HOME:-}" \
  PATH="$PATH" \
  "$TMPDIR/bkgo" test-queue \
  --analytics-database-url "$DATABASE_URL" \
  --auth-mode disabled \
  --cleanup-interval-seconds 0 \
  --host 127.0.0.1 \
  --log-format json \
  --port "$PORT" \
  >"$TMPDIR/bkgo.log" 2>&1 &
SERVER_PID=$!

for _ in $(seq 1 100); do
  if curl -fsS "http://127.0.0.1:$PORT/health" >/dev/null 2>&1; then
    break
  fi
  if ! kill -0 "$SERVER_PID" >/dev/null 2>&1; then
    echo "bkgo test-queue exited early" >&2
    sed -n '1,160p' "$TMPDIR/bkgo.log" >&2
    exit 1
  fi
  sleep 0.1
done
curl -fsS "http://127.0.0.1:$PORT/health" >/dev/null

cat >"$TMPDIR/entries.jsonl" <<'JSONL'
{"test":{"format":"file","path":"lease.test"},"metadata":{"source":"test-queue-lease-smoke"}}
JSONL

export BKTEC_PREVIEW_TEST_QUEUE=true
export BUILDKITE_TEST_ENGINE_OIDC=false
export BUILDKITE_TEST_ENGINE_QUEUE_SERVER_URL="http://127.0.0.1:$PORT"
export BUILDKITE_TEST_ENGINE_QUEUE_ORGANIZATION_UUID="019e8713-0000-7000-8000-000000000010"
export BUILDKITE_TEST_ENGINE_QUEUE_SUITE_UUID="019e8713-0000-7000-8000-000000000011"
export BUILDKITE_ORGANIZATION_SLUG="test-org"
export BUILDKITE_TEST_ENGINE_SUITE_SLUG="test-suite"
export BUILDKITE_PIPELINE_SLUG="test-pipeline"
export BUILDKITE_BUILD_ID="019e8713-0000-7000-8000-000000000012"
export BUILDKITE_JOB_ID="019e8713-0000-7000-8000-000000000013"
export BUILDKITE_STEP_KEY="test-queue-lease-smoke"
export BUILDKITE_TEST_ENGINE_TEST_RUNNER="custom"
export BUILDKITE_TEST_ENGINE_TEST_CMD="true {{testExamples}}"
export BUILDKITE_TEST_ENGINE_TEST_FILE_PATTERN="*.test"
export BUILDKITE_TEST_ENGINE_UPLOAD_RESULTS=false
export BUILDKITE_TEST_ENGINE_QUEUE_BATCH_SIZE=1
export BUILDKITE_TEST_ENGINE_QUEUE_LEASE_SECONDS=1
export BUILDKITE_TEST_ENGINE_QUEUE_POLL_SECONDS=0
export BUILDKITE_TEST_ENGINE_QUEUE_RETRY_POSITION=front

run_bktec() {
  env -i \
    HOME="${HOME:-}" \
    PATH="$PATH" \
    BKTEC_PREVIEW_TEST_QUEUE="$BKTEC_PREVIEW_TEST_QUEUE" \
    BUILDKITE_ANALYTICS_TOKEN= \
    BUILDKITE_BUILD_ID="$BUILDKITE_BUILD_ID" \
    BUILDKITE_JOB_ID="$BUILDKITE_JOB_ID" \
    BUILDKITE_ORGANIZATION_SLUG="$BUILDKITE_ORGANIZATION_SLUG" \
    BUILDKITE_PIPELINE_SLUG="$BUILDKITE_PIPELINE_SLUG" \
    BUILDKITE_STEP_KEY="$BUILDKITE_STEP_KEY" \
    BUILDKITE_TEST_ENGINE_API_ACCESS_TOKEN= \
    BUILDKITE_TEST_ENGINE_OIDC="$BUILDKITE_TEST_ENGINE_OIDC" \
    BUILDKITE_TEST_ENGINE_QUEUE_ACCESS_TOKEN= \
    BUILDKITE_TEST_ENGINE_QUEUE_BATCH_SIZE="$BUILDKITE_TEST_ENGINE_QUEUE_BATCH_SIZE" \
    BUILDKITE_TEST_ENGINE_QUEUE_ENV_FILE="${BUILDKITE_TEST_ENGINE_QUEUE_ENV_FILE:-}" \
    BUILDKITE_TEST_ENGINE_QUEUE_LEASE_SECONDS="$BUILDKITE_TEST_ENGINE_QUEUE_LEASE_SECONDS" \
    BUILDKITE_TEST_ENGINE_QUEUE_METADATA_KEY="${BUILDKITE_TEST_ENGINE_QUEUE_METADATA_KEY:-}" \
    BUILDKITE_TEST_ENGINE_QUEUE_NAME="${BUILDKITE_TEST_ENGINE_QUEUE_NAME:-}" \
    BUILDKITE_TEST_ENGINE_QUEUE_ORGANIZATION_UUID="$BUILDKITE_TEST_ENGINE_QUEUE_ORGANIZATION_UUID" \
    BUILDKITE_TEST_ENGINE_QUEUE_POLL_SECONDS="$BUILDKITE_TEST_ENGINE_QUEUE_POLL_SECONDS" \
    BUILDKITE_TEST_ENGINE_QUEUE_SERVER_URL="$BUILDKITE_TEST_ENGINE_QUEUE_SERVER_URL" \
    BUILDKITE_TEST_ENGINE_QUEUE_SUITE_UUID="$BUILDKITE_TEST_ENGINE_QUEUE_SUITE_UUID" \
    BUILDKITE_TEST_ENGINE_QUEUE_UUID="${BUILDKITE_TEST_ENGINE_QUEUE_UUID:-}" \
    BUILDKITE_TEST_ENGINE_RETRY_COUNT=0 \
    BUILDKITE_TEST_ENGINE_SUITE_SLUG="$BUILDKITE_TEST_ENGINE_SUITE_SLUG" \
    BUILDKITE_TEST_ENGINE_TEST_CMD="$BUILDKITE_TEST_ENGINE_TEST_CMD" \
    BUILDKITE_TEST_ENGINE_TEST_FILE_PATTERN="$BUILDKITE_TEST_ENGINE_TEST_FILE_PATTERN" \
    BUILDKITE_TEST_ENGINE_TEST_RUNNER="$BUILDKITE_TEST_ENGINE_TEST_RUNNER" \
    BUILDKITE_TEST_ENGINE_UPLOAD_RESULTS="$BUILDKITE_TEST_ENGINE_UPLOAD_RESULTS" \
    BUILDKITE_TEST_ENGINE_QUEUE_RETRY_POSITION="$BUILDKITE_TEST_ENGINE_QUEUE_RETRY_POSITION" \
    "$TMPDIR/bktec" "$@"
}

post_queue() {
  local path="${1:?expected path}"
  local body="${2:?expected JSON body}"

  curl -fsS \
    -H "Content-Type: application/json" \
    -d "$body" \
    "http://127.0.0.1:$PORT$path"
}

eval "$(run_bktec queue env --queue-name "$QUEUE_NAME")"
QUEUE_ENV_PATH="$TMPDIR/$BUILDKITE_TEST_ENGINE_QUEUE_ENV_FILE"
run_bktec queue uuid --queue-name "$QUEUE_NAME" >"$QUEUE_ENV_PATH"
source "$QUEUE_ENV_PATH"

echo "--- Pushing one queue entry"
run_bktec queue push --file "$TMPDIR/entries.jsonl"

echo "--- Leasing entry with a one-second expiry"
post_queue "/v1/queues/pop" \
  "{\"queue_uuid\":\"$BUILDKITE_TEST_ENGINE_QUEUE_UUID\",\"limit\":1,\"lease_duration_seconds\":1,\"lease_owner\":\"lease-smoke\"}" \
  >"$TMPDIR/first-pop.json"

python3 - "$TMPDIR/first-pop.json" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as handle:
    response = json.load(handle)

entries = response.get("entries") or []
if response.get("drained"):
    raise SystemExit(f"first pop drained unexpectedly: {response!r}")
if len(entries) != 1:
    raise SystemExit(f"first pop entries={entries!r}, want one entry")
if entries[0].get("attempt") != 1:
    raise SystemExit(f"first pop attempt={entries[0].get('attempt')!r}, want 1")
if entries[0].get("test", {}).get("path") != "lease.test":
    raise SystemExit(f"first pop test={entries[0].get('test')!r}, want lease.test")
PY

FIRST_LEASE_ID="$(python3 - "$TMPDIR/first-pop.json" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as handle:
    response = json.load(handle)
print(response["lease_id"])
PY
)"
ENTRY_UUID="$(python3 - "$TMPDIR/first-pop.json" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as handle:
    response = json.load(handle)
print(response["entries"][0]["uuid"])
PY
)"

echo "--- Waiting for lease expiry"
for _ in $(seq 1 50); do
  run_bktec queue metrics >"$TMPDIR/expired-metrics.json"
  if python3 - "$TMPDIR/expired-metrics.json" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as handle:
    metrics = json.load(handle)

if metrics.get("expired_leased_entries") == 1:
    raise SystemExit(0)
raise SystemExit(1)
PY
  then
    break
  fi
  sleep 0.1
done

python3 - "$TMPDIR/expired-metrics.json" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as handle:
    metrics = json.load(handle)

expected = {
    "state": "closed",
    "queued_entries": 0,
    "leased_entries": 0,
    "expired_leased_entries": 1,
    "total_entries": 1,
}
for key, value in expected.items():
    if metrics.get(key) != value:
        raise SystemExit(f"{key}={metrics.get(key)!r}, want {value!r}; metrics={metrics!r}")
PY

echo "--- Completing expired lease should not delete entries"
post_queue "/v1/queues/complete" \
  "{\"queue_uuid\":\"$BUILDKITE_TEST_ENGINE_QUEUE_UUID\",\"lease_id\":\"$FIRST_LEASE_ID\",\"entry_uuids\":[\"$ENTRY_UUID\"]}" \
  >"$TMPDIR/expired-complete.json"
python3 - "$TMPDIR/expired-complete.json" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as handle:
    response = json.load(handle)
if response.get("deleted") != 0:
    raise SystemExit(f"expired complete deleted={response.get('deleted')!r}, want 0")
PY

echo "--- Leasing recovered entry"
post_queue "/v1/queues/pop" \
  "{\"queue_uuid\":\"$BUILDKITE_TEST_ENGINE_QUEUE_UUID\",\"limit\":1,\"lease_duration_seconds\":30,\"lease_owner\":\"lease-smoke\"}" \
  >"$TMPDIR/second-pop.json"
python3 - "$TMPDIR/second-pop.json" "$ENTRY_UUID" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as handle:
    response = json.load(handle)

entries = response.get("entries") or []
if response.get("drained"):
    raise SystemExit(f"second pop drained unexpectedly: {response!r}")
if len(entries) != 1:
    raise SystemExit(f"second pop entries={entries!r}, want one entry")
if entries[0].get("uuid") != sys.argv[2]:
    raise SystemExit(f"second pop uuid={entries[0].get('uuid')!r}, want recovered {sys.argv[2]!r}")
if entries[0].get("attempt") != 2:
    raise SystemExit(f"second pop attempt={entries[0].get('attempt')!r}, want 2")
PY

SECOND_LEASE_ID="$(python3 - "$TMPDIR/second-pop.json" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as handle:
    response = json.load(handle)
print(response["lease_id"])
PY
)"

echo "--- Completing recovered lease"
post_queue "/v1/queues/complete" \
  "{\"queue_uuid\":\"$BUILDKITE_TEST_ENGINE_QUEUE_UUID\",\"lease_id\":\"$SECOND_LEASE_ID\",\"entry_uuids\":[\"$ENTRY_UUID\"]}" \
  >"$TMPDIR/complete.json"
python3 - "$TMPDIR/complete.json" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as handle:
    response = json.load(handle)
if response.get("deleted") != 1:
    raise SystemExit(f"complete deleted={response.get('deleted')!r}, want 1")
PY

run_bktec queue metrics >"$TMPDIR/drained-metrics.json"
python3 - "$TMPDIR/drained-metrics.json" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as handle:
    metrics = json.load(handle)

expected = {
    "state": "closed",
    "queued_entries": 0,
    "leased_entries": 0,
    "expired_leased_entries": 0,
    "total_entries": 0,
}
for key, value in expected.items():
    if metrics.get(key) != value:
        raise SystemExit(f"{key}={metrics.get(key)!r}, want {value!r}; metrics={metrics!r}")
PY

post_queue "/v1/queues/pop" \
  "{\"queue_uuid\":\"$BUILDKITE_TEST_ENGINE_QUEUE_UUID\",\"limit\":1,\"lease_duration_seconds\":30,\"lease_owner\":\"lease-smoke\"}" \
  >"$TMPDIR/drained-pop.json"
python3 - "$TMPDIR/drained-pop.json" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as handle:
    response = json.load(handle)
if not response.get("drained"):
    raise SystemExit(f"drained pop response={response!r}, want drained true")
if response.get("entries"):
    raise SystemExit(f"drained pop entries={response.get('entries')!r}, want none")
PY

echo "+++ Test Queue lease smoke passed for queue $BUILDKITE_TEST_ENGINE_QUEUE_UUID"
